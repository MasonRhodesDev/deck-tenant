#!/usr/bin/env python3
"""deck-tenant-steam-sync — ensure per-profile Steam shortcuts for registered apps.

For every Steam profile on the device and every app registered with
deck-tenant, ensure a shortcut exists that launches the app's tenant wrapper.
Entries that launch the app directly (e.g. `flatpak run <app-id>`) are
rewritten to the wrapper; stored appids are preserved so artwork keeps working.

Grid artwork is synced from a canonical store at
$XDG_CONFIG_HOME/deck-tenant/art/<appname>/{grid,poster,hero,logo,icon}.<ext>:
for every shortcut (registered or not) whose appname has an art dir, the files
are installed into the profile's config/grid/ keyed to the shortcut's CURRENT
appid — so artwork survives appid churn (shortcuts re-added via Steam's UI get
fresh appids, orphaning appid-keyed art) and covers newly linked accounts.

Run with Steam closed (it rewrites shortcuts.vdf on exit) unless --dry-run.
--art-only skips all shortcuts.vdf writes and only installs artwork; grid
files are safe to add while Steam is running.
A .bak copy is left next to every modified file. Re-run after adding a Steam
profile or registering a new app.
"""
import glob
import os
import shutil
import struct
import subprocess
import sys
import zlib

CONF = os.path.join(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")), "deck-tenant"
)
USERDATA = os.environ.get(
    "DECK_TENANT_STEAM_USERDATA", os.path.expanduser("~/.steam/steam/userdata")
)
DRY = "--dry-run" in sys.argv
ART_ONLY = "--art-only" in sys.argv

# canonical role name -> grid filename for a given appid ("p" poster is the
# 600x900 capsule; bare id is the landscape grid tile)
ART_ROLES = {
    "grid": "{id}{ext}",
    "poster": "{id}p{ext}",
    "hero": "{id}_hero{ext}",
    "logo": "{id}_logo{ext}",
    "icon": "{id}_icon{ext}",
}


def apps():
    tsv = os.path.join(CONF, "apps.tsv")
    if not os.path.exists(tsv):
        return []
    out = []
    for line in open(tsv):
        parts = line.rstrip("\n").split("\t")
        if len(parts) >= 3:
            out.append(tuple(parts[:3]))  # (app_id, name, wrapper); col 4 = shared subpaths
    return out


def parse(data):
    pos = [0]

    def byte():
        pos[0] += 1
        return data[pos[0] - 1]

    def cstr():
        end = data.index(b"\x00", pos[0])
        s = data[pos[0]:end].decode(errors="replace")
        pos[0] = end + 1
        return s

    def obj():
        out = {}
        while True:
            t = byte()
            if t == 8:
                return out
            k = cstr()
            if t == 0:
                out[k] = obj()
            elif t == 1:
                out[k] = cstr()
            elif t == 2:
                out[k] = struct.unpack("<I", data[pos[0]:pos[0] + 4])[0]
                pos[0] += 4
    byte()
    cstr()
    return obj()


def serialize(shortcuts):
    def s(k, v):
        return b"\x01" + k.encode() + b"\x00" + v.encode() + b"\x00"

    def i(k, v):
        return b"\x02" + k.encode() + b"\x00" + struct.pack("<I", v)

    def obj(d):
        out = b""
        for k, v in d.items():
            if isinstance(v, dict):
                out += b"\x00" + k.encode() + b"\x00" + obj(v) + b"\x08"
            elif isinstance(v, int):
                out += i(k, v)
            else:
                out += s(k, v)
        return out

    body = b""
    for k, v in shortcuts.items():
        body += b"\x00" + k.encode() + b"\x00" + obj(v) + b"\x08"
    return b"\x00shortcuts\x00" + body + b"\x08\x08"


def new_entry(name, wrapper):
    appid = zlib.crc32(f'"{wrapper}"{name}'.encode()) | 0x80000000
    return {
        "appid": appid,
        "appname": name,
        "Exe": f'"{wrapper}"',
        "StartDir": f'"{os.path.expanduser("~")}"',
        "icon": "",
        "ShortcutPath": "",
        "LaunchOptions": "",
        "IsHidden": 0,
        "AllowDesktopConfig": 1,
        "AllowOverlay": 1,
        "OpenVR": 0,
        "Devkit": 0,
        "DevkitGameID": "",
        "DevkitOverrideAppID": 0,
        "LastPlayTime": 0,
        "tags": {"0": "Games"},
    }


def sync_art(userdir, shortcuts):
    """Install canonical art for every shortcut whose appname has an art dir,
    keyed to the shortcut's current appid. Returns a list of action strings."""
    actions = []
    grid = os.path.join(userdir, "config", "grid")
    for entry in shortcuts.values():
        if not isinstance(entry, dict):
            continue
        name, appid = entry.get("appname", ""), entry.get("appid")
        src_dir = os.path.join(CONF, "art", name)
        if not name or not appid or not os.path.isdir(src_dir):
            continue
        for fn in sorted(os.listdir(src_dir)):
            role, ext = os.path.splitext(fn)
            if role not in ART_ROLES or not ext:
                continue
            src = os.path.join(src_dir, fn)
            dst = os.path.join(grid, ART_ROLES[role].format(id=appid, ext=ext))
            if os.path.exists(dst) and os.path.getsize(dst) == os.path.getsize(src):
                continue
            if not DRY:
                os.makedirs(grid, exist_ok=True)
                shutil.copy2(src, dst)
            actions.append(f"art {name}/{fn} -> {os.path.basename(dst)}")
    return actions


def main():
    registry = apps()
    if not registry and not ART_ONLY:
        print("no apps registered with deck-tenant")
        return 0
    real = "DECK_TENANT_STEAM_USERDATA" not in os.environ
    if (
        not DRY
        and not ART_ONLY
        and real
        and subprocess.run(["pgrep", "-x", "steam"], capture_output=True).returncode == 0
    ):
        print("error: close Steam first (it overwrites shortcuts.vdf on exit), or use --dry-run / --art-only")
        return 1
    for userdir in sorted(glob.glob(os.path.join(USERDATA, "*/"))):
        profile = os.path.basename(userdir.rstrip("/"))
        if not profile.isdigit():
            continue
        path = os.path.join(userdir, "config", "shortcuts.vdf")
        exists = os.path.exists(path)
        shortcuts = parse(open(path, "rb").read()) if exists else {}
        if ART_ONLY:
            art = sync_art(userdir, shortcuts)
            print(f"profile {profile}: {art if art else 'art ok'}")
            continue
        actions = []
        for app_id, name, wrapper in registry:
            has = False
            for key, entry in shortcuts.items():
                if not isinstance(entry, dict):
                    continue
                exe = entry.get("Exe", "")
                opts = entry.get("LaunchOptions", "")
                if wrapper in exe:
                    has = True
                elif (
                    app_id.lower() in (exe + " " + opts).lower()
                    or entry.get("appname", "") == name
                ):
                    entry["Exe"] = f'"{wrapper}"'
                    entry["LaunchOptions"] = ""
                    entry["StartDir"] = f'"{os.path.expanduser("~")}"'
                    actions.append(f"rewire {entry.get('appname', key)}")
                    has = True
            if not has:
                free = next(str(n) for n in range(len(shortcuts) + 1) if str(n) not in shortcuts)
                shortcuts[free] = new_entry(name, wrapper)
                actions.append(f"create {name}")
        if DRY:
            art = sync_art(userdir, shortcuts)
            print(f"[dry-run] profile {profile}: would {actions + art}" if actions + art
                  else f"[dry-run] profile {profile}: ok")
            continue
        if actions:
            if exists:
                shutil.copy(path, path + ".bak")
            os.makedirs(os.path.dirname(path), exist_ok=True)
            open(path, "wb").write(serialize(shortcuts))
        art = sync_art(userdir, shortcuts)
        print(f"profile {profile}: {actions + art}" if actions + art else f"profile {profile}: ok")
    return 0


if __name__ == "__main__":
    sys.exit(main())
