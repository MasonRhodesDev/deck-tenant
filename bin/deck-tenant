#!/bin/bash
# deck-tenant — per-Steam-account virtual homes on a shared-user device.
#
# SteamOS runs every Steam profile as the one `deck` Linux user, so non-Steam
# apps (Discord, Kodi, browsers, …) share logins and state. deck-tenant gives
# each Steam account a virtual home and launches apps inside it: flatpak and
# XDG apps resolve $HOME from the environment, so everything an app persists
# lands in the tenant's home — no per-app path knowledge required.
#
# Session plumbing (D-Bus, Wayland, PipeWire, portals) lives in
# $XDG_RUNTIME_DIR and is independent of $HOME, so apps keep display, audio,
# and keyring access. The desktop session itself is never touched.
#
# Commands:
#   deck-tenant active                    print active Steam account id (or 'default')
#   deck-tenant home                      print (and provision) the tenant home
#   deck-tenant run [--] <cmd> [args…]    run a command inside the tenant home
#   deck-tenant register --app-id <flatpak-id> --name <Name> [--flags-file <path>]
#                                         make a flatpak app multi-tenant:
#                                         wrapper, desktop shadow, guard entry
#   deck-tenant unregister <flatpak-id>   undo register (tenant data is kept)
#   deck-tenant list                      list registered apps
#   deck-tenant ps                        running processes with tenant owners
#   deck-tenant setup                     one-time per-user wiring: enable the
#                                         guard units; for a user-level pacman
#                                         root also PATH + ExecStart drop-ins
set -u

STATE_ROOT="${DECK_TENANT_ROOT:-$HOME/.local/share/deck-tenant}"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/deck-tenant"
APPS_TSV="$CONF_DIR/apps.tsv"
LOGINUSERS="${DECK_TENANT_LOGINUSERS:-$HOME/.steam/steam/config/loginusers.vdf}"

# Configs shared across tenants so apps keep the device's look and feel.
# Steam's own dirs are DELIBERATELY shared: Steam is the driving application
# for tenant state and must never fork per-tenant — if anything inside a
# tenant context ever reaches Steam, it must find the real installation.
SHARED_LINKS=(
    .config/kdeglobals .config/gtk-3.0 .config/gtk-4.0 .config/fontconfig
    .config/Kvantum .icons .themes .local/share/fonts .local/share/icons
    .steam .local/share/Steam
    Downloads Music Pictures Videos
)

active_id() {
    local id
    id=$(python3 - "$LOGINUSERS" <<'PY' 2>/dev/null
import re, sys
try:
    d = open(sys.argv[1], encoding='utf-8', errors='replace').read()
except OSError:
    raise SystemExit
for m in re.finditer(r'"(\d{17})"\s*\{(.*?)\}', d, re.S):
    if re.search(r'"MostRecent"\s*"1"', m.group(2)):
        print(int(m.group(1)) - 76561197960265728)
        break
PY
    )
    echo "${id:-default}"
}

tenant_home() {
    local id="$1" home
    home="$STATE_ROOT/homes/$id"
    if [ ! -d "$home" ]; then
        mkdir -p "$home/.config" "$home/.local/share"
        local rel src dst
        for rel in "${SHARED_LINKS[@]}"; do
            src="$HOME/$rel"
            dst="$home/$rel"
            [ -e "$src" ] || continue
            mkdir -p "$(dirname "$dst")"
            ln -sfn "$src" "$dst"
        done
    fi
    echo "$home"
}

cmd_run() {
    [ "${1:-}" = "--" ] && shift
    [ $# -ge 1 ] || { echo "usage: deck-tenant run [--] <cmd> [args…]" >&2; exit 2; }
    case "$(basename "$1")${2:+ $(basename "$2")}" in
        steam*|*" com.valvesoftware.Steam"*)
            echo "deck-tenant: refusing to run Steam in a virtual home — Steam drives tenant state and must use the real home" >&2
            exit 1 ;;
    esac
    local id home unit
    id=$(active_id)
    home=$(tenant_home "$id")
    unit="deck-tenant-$id-$(basename "$1" | tr -cd 'a-zA-Z0-9')-$$"
    if command -v systemd-run >/dev/null 2>&1; then
        exec systemd-run --user --scope --quiet --unit "$unit" \
            env HOME="$home" DECK_TENANT="$id" DECK_TENANT_REAL_HOME="$HOME" "$@"
    fi
    exec env HOME="$home" DECK_TENANT="$id" DECK_TENANT_REAL_HOME="$HOME" "$@"
}

cmd_register() {
    local app_id="" name="" flags_file=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --app-id) app_id="$2"; shift 2 ;;
            --name) name="$2"; shift 2 ;;
            --flags-file) flags_file="$2"; shift 2 ;;
            *) echo "unknown option: $1" >&2; exit 2 ;;
        esac
    done
    [ -n "$app_id" ] && [ -n "$name" ] || { echo "usage: deck-tenant register --app-id <flatpak-id> --name <Name> [--flags-file <path>]" >&2; exit 2; }
    case "$app_id" in
        com.valvesoftware.Steam|*.Steam)
            echo "deck-tenant: refusing to register Steam — it drives tenant state and must never be tenant-scoped" >&2
            exit 1 ;;
    esac

    local slug wrapper self
    slug=$(echo "$name" | tr '[:upper:] ' '[:lower:]-')
    wrapper="$HOME/.local/bin/tenant-$slug"
    self=$(readlink -f "$0")

    # the app itself must exist before we point launchers at it
    if ! flatpak info "$app_id" >/dev/null 2>&1; then
        echo "deck-tenant: installing $app_id from flathub"
        flatpak install -y --noninteractive flathub "$app_id" || {
            echo "deck-tenant: could not install $app_id" >&2; exit 1; }
    fi

    # 1. launch wrapper
    #
    # Flatpak apps get tenancy via an ~/.var/app/<id> symlink swap into the
    # tenant home, NOT via $HOME override: zypak (Electron flatpaks like
    # Discord) re-spawns children through the flatpak portal, which resolves
    # the app data dir from the real home — an env-HOME mismatch SIGTRAPs it.
    # The whole app-data dir is the unit of isolation, so no app-internal
    # path knowledge is needed, and $HOME stays real (portals, zypak, KDE
    # theming all unaffected).
    cat > "$wrapper" <<WRAP
#!/bin/bash
# Generated by deck-tenant: launch $name ($app_id) as the active tenant.
set -u
current=\$("$self" active)
tenant_dir="$STATE_ROOT/homes/\$current/.var/app/$app_id"
real_dir="\$HOME/.var/app/$app_id"

# Apps are single-instance per config dir; an instance from another tenant
# must not be focused into this one's session.
marker="$STATE_ROOT/active/$app_id"
if [ -f "\$marker" ] && [ "\$(cat "\$marker" 2>/dev/null)" != "\$current" ]; then
    if flatpak ps --columns=application 2>/dev/null | grep -qx "$app_id"; then
        flatpak kill "$app_id" 2>/dev/null
        for _ in \$(seq 1 20); do flatpak ps --columns=application 2>/dev/null | grep -qx "$app_id" || break; sleep 0.5; done
    fi
fi
mkdir -p "$STATE_ROOT/active"; printf '%s\n' "\$current" > "\$marker"

# Adopt any pre-existing (pre-deck-tenant) app data as the current tenant's.
if [ -e "\$real_dir" ] && [ ! -L "\$real_dir" ]; then
    if [ -e "\$tenant_dir" ]; then
        mv "\$real_dir" "\$real_dir.pre-deck-tenant"
    else
        mkdir -p "\$(dirname "\$tenant_dir")"
        mv "\$real_dir" "\$tenant_dir"
    fi
fi
mkdir -p "\$tenant_dir"
ln -sfn "\$tenant_dir" "\$real_dir"

flags=()
FLAGS_FILE="${flags_file}"
if [ -n "\$FLAGS_FILE" ] && [ -f "\$FLAGS_FILE" ]; then
    mapfile -t flags < <(grep -v '^\s*#' "\$FLAGS_FILE" | grep -v '^\s*\$')
fi
exec "$self" _track "$app_id" "\$current" -- flatpak run "$app_id" "\${flags[@]}" "\$@"
WRAP
    chmod 755 "$wrapper"

    # 2. desktop entry shadow (menu launches + URI handlers keep tenancy)
    local exported="/var/lib/flatpak/exports/share/applications/$app_id.desktop"
    local icon="$app_id" mime=""
    if [ -f "$exported" ]; then
        mime=$(grep -m1 '^MimeType=' "$exported" || true)
    fi
    install -Dm644 /dev/stdin "$HOME/.local/share/applications/$app_id.desktop" <<DESK
[Desktop Entry]
Name=$name
Comment=$name (per-Steam-account profile via deck-tenant)
Exec=$wrapper %U
Icon=$icon
Type=Application
Categories=Network;
$mime
DESK
    command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database "$HOME/.local/share/applications" || true

    # 3. registry entry (drives the session guard and Steam-shortcut ensure)
    mkdir -p "$CONF_DIR"
    touch "$APPS_TSV"
    grep -v "^$app_id	" "$APPS_TSV" > "$APPS_TSV.tmp" || true
    printf '%s\t%s\t%s\n' "$app_id" "$name" "$wrapper" >> "$APPS_TSV.tmp"
    mv "$APPS_TSV.tmp" "$APPS_TSV"
    echo "registered $name ($app_id): wrapper=$wrapper"
    echo "run deck-tenant-steam-sync (Steam closed) to ensure per-profile Steam shortcuts"
}

# _track <app-id> <tenant> -- <cmd…>: run a flatpak app and record which tenant
# owns its instance, so the guard can find and kill exactly the right
# processes on user-state changes. Records live in $STATE_ROOT/running/<instance>.
cmd__track() {
    local app_id="$1" tenant="$2"; shift 2
    [ "${1:-}" = "--" ] && shift
    "$@" &
    local pid=$!
    local run_dir="$STATE_ROOT/running" inst=""
    mkdir -p "$run_dir"
    local i
    for i in $(seq 1 30); do
        inst=$(flatpak ps --columns=instance,application 2>/dev/null | awk -v a="$app_id" '$2==a {print $1; exit}')
        [ -n "$inst" ] && break
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.5
    done
    [ -n "$inst" ] && printf '%s\t%s\n' "$tenant" "$app_id" > "$run_dir/$inst"
    wait "$pid"; local rc=$?
    [ -n "$inst" ] && rm -f "$run_dir/$inst"
    exit "$rc"
}

# ps: everything currently running with a tenant owner
cmd_ps() {
    local run_dir="$STATE_ROOT/running" live inst owner app
    live=$(flatpak ps --columns=instance,application 2>/dev/null)
    printf '%-12s %-12s %s\n' OWNER INSTANCE APP
    if [ -d "$run_dir" ]; then
        for f in "$run_dir"/*; do
            [ -e "$f" ] || continue
            inst=$(basename "$f")
            if ! echo "$live" | awk '{print $1}' | grep -qx "$inst"; then
                rm -f "$f"; continue   # stale record
            fi
            IFS=$'\t' read -r owner app < "$f"
            printf '%-12s %-12s %s\n' "$owner" "$inst" "$app"
        done
    fi
    systemctl --user list-units --no-legend 'deck-tenant-*' 2>/dev/null \
        | awk '{print $1}' | grep -E '^deck-tenant-[0-9a-z]+-' | while read -r u; do
        owner=$(echo "$u" | sed -E 's/^deck-tenant-([0-9a-z]+)-.*/\1/')
        printf '%-12s %-12s %s\n' "$owner" "scope" "$u"
    done
}

cmd_unregister() {
    local app_id="${1:-}"
    [ -n "$app_id" ] || { echo "usage: deck-tenant unregister <flatpak-id>" >&2; exit 2; }
    local line name wrapper
    line=$(grep "^$app_id	" "$APPS_TSV" 2>/dev/null) || { echo "not registered: $app_id" >&2; exit 1; }
    name=$(echo "$line" | cut -f2); wrapper=$(echo "$line" | cut -f3)
    rm -f "$wrapper" "$HOME/.local/share/applications/$app_id.desktop" "$STATE_ROOT/active/$app_id"
    grep -v "^$app_id	" "$APPS_TSV" > "$APPS_TSV.tmp" || true; mv "$APPS_TSV.tmp" "$APPS_TSV"
    # materialize the active tenant's data back as the real app dir
    local real="$HOME/.var/app/$app_id"
    if [ -L "$real" ]; then
        local target; target=$(readlink -f "$real")
        rm "$real"
        [ -d "$target" ] && cp -a "$target" "$real"
    fi
    echo "unregistered $name ($app_id); tenant data kept under $STATE_ROOT/homes/"
    echo "note: Steam shortcuts still point at the removed wrapper — re-run deck-tenant-steam-sync or edit them"
}

cmd_list() {
    [ -f "$APPS_TSV" ] && column -t -s "	" "$APPS_TSV" || echo "no apps registered"
}

# setup: per-user wiring after a pacman install (idempotent). The shipped
# units are canonical (ExecStart=/usr/bin/…); when installed into a user-level
# pacman root (e.g. ~/.local/share/deck-pkgs on SteamOS) this additionally
# adds the root's bin dir to PATH, links the units into the user manager, and
# writes ExecStart drop-in overrides pointing at the actual binary location —
# the packaged unit files themselves are never edited.
cmd_setup() {
    local self bindir pkgroot unit_dir u
    self=$(readlink -f "$0")
    bindir=$(dirname "$self")
    case "$bindir" in
        /usr/bin) pkgroot="" ;;                     # system install
        */usr/bin) pkgroot="${bindir%/usr/bin}" ;;  # user-level pacman root
        *) echo "deck-tenant setup: unexpected install location $bindir (expected .../usr/bin)" >&2; exit 1 ;;
    esac
    unit_dir="$pkgroot/usr/lib/systemd/user"

    local units=(deck-tenant-login.path deck-tenant-login.service
                 deck-tenant-steamwatch.path deck-tenant-steamwatch.service)
    for u in "${units[@]}"; do
        [ -f "$unit_dir/$u" ] || { echo "deck-tenant setup: missing $unit_dir/$u" >&2; exit 1; }
    done

    if [ -n "$pkgroot" ]; then
        # PATH snippet — only needed for a non-/usr/bin install location
        local rc="$HOME/.bashrc" snippet="export PATH=\"$bindir:\$PATH\""
        if ! grep -qsF "$snippet" "$rc"; then
            printf '\n# added by deck-tenant setup\n%s\n' "$snippet" >> "$rc"
            echo "setup: added $bindir to PATH in $rc (takes effect in new shells)"
        fi

        # make the units visible to the user manager (link, don't copy)
        for u in "${units[@]}"; do
            systemctl --user link --force "$unit_dir/$u" || {
                echo "deck-tenant setup: could not link $u" >&2; exit 1; }
        done

        # keep shipped units canonical; retarget ExecStart for this root
        local dropdir exec_line
        for u in deck-tenant-login.service deck-tenant-steamwatch.service; do
            exec_line=$(sed -n 's/^ExecStart=//p' "$unit_dir/$u")
            dropdir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/$u.d"
            mkdir -p "$dropdir"
            printf '# Generated by deck-tenant setup: binaries live under %s\n[Service]\nExecStart=\nExecStart=%s\n' \
                "$bindir" "${exec_line/#\/usr\/bin\//$bindir/}" \
                > "$dropdir/50-deck-tenant-root.conf"
        done
    fi

    systemctl --user daemon-reload
    systemctl --user enable --now deck-tenant-login.path \
        deck-tenant-steamwatch.path deck-tenant-steamwatch.service || {
        echo "deck-tenant setup: could not enable the guard units" >&2; exit 1; }
    echo "setup: guard units enabled (login.path, steamwatch.path, steamwatch.service)"
}

case "${1:-}" in
    active)   active_id ;;
    home)     tenant_home "$(active_id)" ;;
    run)      shift; cmd_run "$@" ;;
    register) shift; cmd_register "$@" ;;
    unregister) shift; cmd_unregister "$@" ;;
    ps)       cmd_ps ;;
    _track)   shift; cmd__track "$@" ;;
    list)     cmd_list ;;
    setup)    cmd_setup ;;
    *) awk 'NR < 2 { next } !/^#/ { exit } { sub(/^# ?/, ""); print }' "$0"; exit 2 ;;
esac
