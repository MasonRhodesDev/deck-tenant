#!/bin/bash
# deck-tenant-guard — event-driven alignment of app lifetimes with Steam tenancy.
#
# No polling. The packaged systemd units deliver the events:
#   deck-tenant-login.path      loginusers.vdf modified  -> handle-login
#   deck-tenant-steamwatch.path steam.pid (re)written    -> watch-steam
#
#   handle-login   oneshot: if the active Steam account changed, close other
#                  tenants' tracked processes and restart registered apps that
#                  were running, now under the new tenant
#   watch-steam    block on a pidfd until the running Steam exits (kernel
#                  event, zero CPU), then handle the session boundary:
#                  gamescope session -> close all tenant-owned processes;
#                  desktop session   -> leave everything alone (same person)
set -u

STATE_ROOT="${DECK_TENANT_ROOT:-$HOME/.local/share/deck-tenant}"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/deck-tenant"
APPS_TSV="$CONF_DIR/apps.tsv"
RUN_DIR="$STATE_ROOT/running"
LAST="$STATE_ROOT/last-tenant"
DRYRUN=${DECK_TENANT_GUARD_DRYRUN:-}

# resolve the sibling CLI absolutely — systemd services don't have the
# package root in PATH
DT="$(dirname "$(readlink -f "$0")")/deck-tenant"

log() { echo "$*"; }
act() { if [ -n "$DRYRUN" ]; then echo "DRYRUN: $*"; else "$@"; fi; }

app_running() { flatpak ps --columns=application 2>/dev/null | grep -qx "$1"; }

registered() { [ -f "$APPS_TSV" ] && cut -f1,3 "$APPS_TSV"; }

# Desktop of the active seat session: "gamescope" in game mode, "KDE" (etc.)
# in desktop mode, empty during transitions.
active_desktop() {
    local s d a
    for s in $(loginctl list-sessions --no-legend 2>/dev/null | awk '{print $1}'); do
        a=$(loginctl show-session "$s" -p Active --value 2>/dev/null)
        d=$(loginctl show-session "$s" -p Desktop --value 2>/dev/null)
        if [ "$a" = "yes" ] && [ -n "$d" ]; then echo "$d"; return; fi
    done
}

# Kill precisely by tracked ownership: flatpak instances via their run records
# (written by `deck-tenant _track`), non-flatpak launches via their
# tenant-named systemd scopes. Empty filter = kill every owner's processes.
kill_tracked() {
    local filter="${1:-}" f inst owner app u
    for f in "$RUN_DIR"/*; do
        [ -e "$f" ] || continue
        inst=$(basename "$f")
        IFS=$'\t' read -r owner app < "$f"
        if [ -z "$filter" ] || [ "$owner" != "$filter" ]; then
            log "closing $app (instance $inst, owner $owner)"
            act flatpak kill "$inst" 2>/dev/null || act flatpak kill "$app"
            rm -f "$f"
        fi
    done
    while read -r u; do
        [ -n "$u" ] || continue
        owner=$(echo "$u" | sed -E 's/^deck-tenant-([0-9a-z]+)-.*/\1/')
        if [ -z "$filter" ] || [ "$owner" != "$filter" ]; then
            log "stopping scope $u (owner $owner)"
            act systemctl --user stop "$u"
        fi
    done < <(systemctl --user list-units --no-legend 'deck-tenant-*' 2>/dev/null | awk '{print $1}' | grep -E '^deck-tenant-[0-9a-z]+-.*\.scope$' || true)
}

kill_registered() {
    kill_tracked ""   # session boundary: everything tenant-owned goes
    local app_id wrapper
    while IFS=$'\t' read -r app_id wrapper; do
        [ -n "$app_id" ] || continue
        if app_running "$app_id"; then
            log "closing $app_id"
            act flatpak kill "$app_id"
        fi
    done < <(registered)
}

restart_registered_running() {
    local new_tenant="$1"
    local app_id wrapper was_running="" pair
    while IFS=$'\t' read -r app_id wrapper; do
        [ -n "$app_id" ] || continue
        app_running "$app_id" && was_running="$was_running $app_id:$wrapper"
    done < <(registered)
    # everything owned by other tenants dies, registered or not
    kill_tracked "$new_tenant"
    for pair in $was_running; do
        app_id="${pair%%:*}"; wrapper="${pair#*:}"
        for _ in $(seq 1 20); do app_running "$app_id" || break; sleep 0.5; done
        if ! app_running "$app_id"; then
            log "restarting $app_id for tenant $new_tenant"
            # systemd-run: the app must not be a child of this guard
            act systemd-run --user --collect "$wrapper"
        fi
    done
}

cmd_handle_login() {
    mkdir -p "$STATE_ROOT"
    local uid last
    uid=$("$DT" active)
    last=$(cat "$LAST" 2>/dev/null || echo "")
    if [ -n "$last" ] && [ -n "$uid" ] && [ "$uid" != "$last" ]; then
        log "steam account changed ($last -> $uid)"
        restart_registered_running "$uid"
    fi
    printf '%s\n' "$uid" > "$LAST"
}

cmd_watch_steam() {
    local pid="${DECK_TENANT_STEAM_PID:-}"
    if [ -z "$pid" ]; then
        pid=$(cat "$HOME/.steam/steam.pid" 2>/dev/null) || exit 0
    fi
    kill -0 "$pid" 2>/dev/null || exit 0
    log "watching steam (pid $pid) via pidfd"
    python3 - "$pid" <<'PY'
import os, select, sys
try:
    fd = os.pidfd_open(int(sys.argv[1]))
except OSError:
    sys.exit(0)          # raced: already gone
select.select([fd], [], [])   # kernel wakes us exactly when the process exits
PY
    local d
    d=$(active_desktop)
    case "$d" in
        gamescope|"")
            log "steam exited (session: ${d:-none}) — closing tenant-owned apps"
            kill_registered
            ;;
        *)
            log "steam exited in desktop session ($d) — leaving apps running"
            ;;
    esac
}

case "${1:-}" in
    handle-login) cmd_handle_login ;;
    watch-steam)  cmd_watch_steam ;;
    *) echo "usage: deck-tenant-guard <handle-login|watch-steam> (driven by systemd path units)" >&2; exit 2 ;;
esac
