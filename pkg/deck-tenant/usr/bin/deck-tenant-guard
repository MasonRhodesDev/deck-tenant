#!/bin/bash
# deck-tenant-guard — align registered apps' lifetimes with Steam tenancy.
#
#  - Steam exits inside game mode (gamescope session) -> close registered apps:
#    the session is over and the next profile must not inherit them.
#  - The active Steam account changes while an app runs (desktop re-login)
#    -> close it and reopen it under the new tenant.
#  - Steam exits in desktop mode -> leave apps alone (same person).
#
# Needed because flatpak apps run in their own systemd scopes and survive
# Steam, the session, and profile switches on their own.
set -u

POLL=${DECK_TENANT_GUARD_POLL:-5}
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/deck-tenant"
APPS_TSV="$CONF_DIR/apps.tsv"
DRYRUN=${DECK_TENANT_GUARD_DRYRUN:-}

# resolve the sibling CLI absolutely — systemd services don't have the
# package root in PATH
DT="$(dirname "$(readlink -f "$0")")/deck-tenant"

log() { echo "$*"; }
act() { if [ -n "$DRYRUN" ]; then echo "DRYRUN: $*"; else "$@"; fi; }

app_running() { flatpak ps --columns=application 2>/dev/null | grep -qx "$1"; }
steam_running() { pgrep -x steam >/dev/null 2>&1; }

registered() { [ -f "$APPS_TSV" ] && cut -f1,3 "$APPS_TSV"; }

active_desktop() {
    local s d a
    for s in $(loginctl list-sessions --no-legend 2>/dev/null | awk '{print $1}'); do
        a=$(loginctl show-session "$s" -p Active --value 2>/dev/null)
        d=$(loginctl show-session "$s" -p Desktop --value 2>/dev/null)
        if [ "$a" = "yes" ] && [ -n "$d" ]; then echo "$d"; return; fi
    done
}

RUN_DIR="${DECK_TENANT_ROOT:-$HOME/.local/share/deck-tenant}/running"

# Kill precisely by tracked ownership: flatpak instances via their run records
# (written by `deck-tenant _track`), non-flatpak launches via their
# tenant-named systemd scopes. Empty filter = kill every owner's processes.
kill_tracked() {
    local filter="${1:-}" f inst owner app u
    for f in "$RUN_DIR"/*; do
        [ -e "$f" ] || continue
        inst=$(basename "$f")
        IFS=$'\t' read -r owner app < "$f"
        if [ -z "$filter" ] || [ "$owner" != "$filter" ]; then
            log "closing $app (instance $inst, owner $owner)"
            act flatpak kill "$inst" 2>/dev/null || act flatpak kill "$app"
            rm -f "$f"
        fi
    done
    while read -r u; do
        [ -n "$u" ] || continue
        owner=$(echo "$u" | sed -E 's/^deck-tenant-([0-9a-z]+)-.*/\1/')
        if [ -z "$filter" ] || [ "$owner" != "$filter" ]; then
            log "stopping scope $u (owner $owner)"
            act systemctl --user stop "$u"
        fi
    done < <(systemctl --user list-units --no-legend 'deck-tenant-*' 2>/dev/null | awk '{print $1}' | grep -E '^deck-tenant-[0-9a-z]+-.*\.scope$' || true)
}

kill_registered() {
    kill_tracked ""   # session boundary: everything tenant-owned goes
    local app_id wrapper
    while IFS=$'\t' read -r app_id wrapper; do
        [ -n "$app_id" ] || continue
        if app_running "$app_id"; then
            log "closing $app_id"
            act flatpak kill "$app_id"
        fi
    done < <(registered)
}

restart_registered_running() {
    local new_tenant="$1"
    local app_id wrapper was_running="" pair
    while IFS=$'\t' read -r app_id wrapper; do
        [ -n "$app_id" ] || continue
        app_running "$app_id" && was_running="$was_running $app_id:$wrapper"
    done < <(registered)
    # everything owned by other tenants dies, registered or not
    kill_tracked "$new_tenant"
    for pair in $was_running; do
        app_id="${pair%%:*}"; wrapper="${pair#*:}"
        for _ in $(seq 1 20); do app_running "$app_id" || break; sleep 0.5; done
        if ! app_running "$app_id"; then
            log "restarting $app_id for tenant $new_tenant"
            # systemd-run: the app must not be a child of this guard
            act systemd-run --user --collect "$wrapper"
        fi
    done
}

last_uid=$("$DT" active)
steam_was=""
steam_running && steam_was=1

while true; do
    uid=$("$DT" active)
    if [ -n "$uid" ] && [ "$uid" != "$last_uid" ]; then
        log "steam account changed ($last_uid -> $uid)"
        restart_registered_running "$uid"
    fi
    last_uid=$uid

    if steam_running; then
        steam_was=1
    elif [ -n "$steam_was" ]; then
        steam_was=""
        d=$(active_desktop)
        case "$d" in
            gamescope|"")
                log "steam exited (session: ${d:-none}) — closing registered apps"
                kill_registered
                ;;
            *)
                log "steam exited in desktop session ($d) — leaving apps running"
                ;;
        esac
    fi
    sleep "$POLL"
done
